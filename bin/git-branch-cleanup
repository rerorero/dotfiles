#!/bin/bash
#
# Git branch cleanup script
# Lists and removes local branches not touched in the last 30 days
#

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Days threshold (default: 30)
DAYS=${1:-30}

# Get current branch
current_branch=$(git rev-parse --abbrev-ref HEAD)

# Get main/master branch name
main_branch=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@' || echo "main")

echo -e "${BLUE}Current branch: ${GREEN}${current_branch}${NC}"
echo -e "${YELLOW}Looking for branches not touched in the last ${DAYS} days...${NC}"
echo ""

# Calculate threshold date
threshold_date=$(date -v-${DAYS}d +%s 2>/dev/null || date -d "${DAYS} days ago" +%s)

# Get list of branches with their last commit date
old_branches=()
while IFS= read -r line; do
    branch_name=$(echo "$line" | awk '{print $1}')
    commit_date=$(echo "$line" | awk '{print $2}')

    # Skip current branch, main, and master
    if [[ "$branch_name" == "$current_branch" ]] || \
       [[ "$branch_name" == "$main_branch" ]] || \
       [[ "$branch_name" == "master" ]]; then
        continue
    fi

    # Check if branch is older than threshold
    if [[ $commit_date -lt $threshold_date ]]; then
        days_ago=$(( ($(date +%s) - commit_date) / 86400 ))
        old_branches+=("$branch_name ($days_ago days ago)")
    fi
done < <(git for-each-ref --format='%(refname:short) %(committerdate:unix)' refs/heads/)

if [ ${#old_branches[@]} -eq 0 ]; then
    echo -e "${GREEN}No branches older than ${DAYS} days found!${NC}"
    exit 0
fi

echo -e "${YELLOW}The following branches haven't been touched in ${DAYS}+ days:${NC}"
printf '%s\n' "${old_branches[@]}"
echo ""
read -p "Delete these branches? [y/N] " -n 1 -r
echo

if [[ $REPLY =~ ^[Yy]$ ]]; then
    for branch_info in "${old_branches[@]}"; do
        branch_name=$(echo "$branch_info" | awk '{print $1}')
        git branch -D "$branch_name" && echo -e "${GREEN}Deleted: ${branch_name}${NC}"
    done
    echo ""
    echo -e "${GREEN}Branch cleanup complete!${NC}"
else
    echo -e "${YELLOW}Cleanup cancelled.${NC}"
fi
